{
  "name": "perseus",
  "version": "0.2.0",
  "private": true,
  "description": "Perseus is a desktop tool for translating English Wikipedia articles into Persian or Tajik Wikipedia-compatible Wikitext, helping bridge the gap in quality and completeness across languages.",
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "tauri": "tauri",
    "version": "node scripts/sync-version.mjs",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-select": "2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "nano-staged": "^1.0.2",
    "postcss": "^8.5.16",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "nano-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged",
    "pre-push": "pnpm version & pnpm test"
  }
}
