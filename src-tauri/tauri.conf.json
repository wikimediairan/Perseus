{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Perseus",
  "version": "0.2.0-beta",
  "identifier": "org.wikimedia.perseus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Perseus",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
